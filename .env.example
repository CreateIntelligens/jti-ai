# Gemini API Keys (comma-separated, startup auto-discovers stores per key)
# 取得方式：https://aistudio.google.com/apikey
GEMINI_API_KEYS=YOUR_KEY_1,YOUR_KEY_2

# Managed app -> Gemini key display name mapping
APP_KEY_MAP=jti:JTI傑太日煙,hciot:HCIOT護聯

# Gemini Model Name
GEMINI_MODEL_NAME=gemini-3.1-flash-lite

# TTS (背景生成；聊天 API 不阻塞)
TTS_API_URL=http://10.9.0.35:8001/tts_stream

# 數字正規化 (數字轉中文 + 繁→簡)
# 設定後優先呼叫 API，失敗時 fallback regex；留空則直接用本地 regex
NORMALIZE_API_URL=http://10.9.0.35:8956/normalize
TTS_TIMEOUT_SECONDS=20
TTS_CACHE_TTL_SECONDS=900
TTS_MAX_JOBS=500
JTI_TTS_CHARACTER=hayley
HCIOT_TTS_CHARACTER=healthy2

# 伺服器 Port
PORT=8008

# Admin API Key
ADMIN_API_KEY=your-admin-key-here

# ============================================================
# 資料庫連線 (DocumentDB 主 / Atlas 備援)
# ============================================================
# 主庫 MONGODB_URI：正式用 AWS DocumentDB，經 db-tunnel 容器連線。
#   - backend 連 db-tunnel:27017（容器會自動判斷 VPC 內直連 / VPC 外走跳板）
#   - 走 tunnel 連 localhost/容器名時，必須帶下列參數：
#       tlsAllowInvalidHostnames=true（憑證 CN 與 db-tunnel 不符）
#       directConnection=true（不讓 driver 去找 replica set 內部成員）
#   - tlsCAFile 指向容器內掛入的 AWS RDS CA bundle
MONGODB_URI=mongodb://docdbadmin:XXXXXXXX@db-tunnel:27017/?tls=true&tlsCAFile=/app/global-bundle.pem&tlsAllowInvalidHostnames=true&directConnection=true&retryWrites=false

# 備援庫 MONGODB_URI_FALLBACK：DocumentDB/跳板長時間不可用時，app 啟動時
# 自動 fallback 連這個（Atlas）。留空則不啟用 fallback。
# 注意：fallback 期間寫入的資料需事後用 scripts/merge_atlas_to_documentdb.py 補回主庫。
MONGODB_URI_FALLBACK=mongodb+srv://XXXX_db_user:XXXXXXXXX@poc0.rsin8mu.mongodb.net/?appName=poc0

# (選) 啟動時試連主庫的逾時毫秒數，逾時即 fallback。預設 5000。
MONGODB_PROBE_TIMEOUT_MS=5000

# ---- db-tunnel 容器設定（docker-compose 讀取）----
# DocumentDB cluster endpoint（容器探測 / 轉發目標）
DOCDB_ENDPOINT=us-west-2-mongodb-cluster.cluster-XXXXXXXX.us-west-2.docdb.amazonaws.com
DOCDB_PORT=27017
# 跳板機（僅 VPC 外的部署會用到；VPC 內 socat 直連不需要）
BASTION_HOST=XX.XX.XX.XX
BASTION_USER=ec2-user

# Frontend allowed pages (comma-separated): jti, hciot, home
VITE_PUBLIC_ALLOWED_PAGES=jti

# Restricted hosts (comma-separated)
VITE_PUBLIC_RESTRICTED_HOSTS=123.asd.ai

# HCIoT header 右側「TTS 管理後台」按鈕（留空則不顯示）
VITE_HCIOT_EXTERNAL_LINK_URL=

# Session JWT 簽章金鑰
SESSION_JWT_SECRET=

# 對外 API Key 加密金鑰 (Fernet)
# 用於可逆加密對外 sk-xxx 金鑰，讓 admin/user 事後能 reveal 複製。
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：更換此金鑰會使既有加密的金鑰無法解密。
API_ENCRYPTION_KEY=
