# Gemini API Key
# 取得方式：https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Gemini Model Name
GEMINI_MODEL_NAME=gemini-2.5-flash

# ===== JTI 知識庫 (Google AI Studio > File Search Store) =====
JTI_STORE_ID_ZH=your-jti-zh-store-id
JTI_STORE_ID_EN=your-jti-en-store-id

# ===== HCIoT 知識庫 =====
HCIOT_STORE_ID_ZH=your-hciot-zh-store-id
HCIOT_STORE_ID_EN=your-hciot-en-store-id

# 伺服器 Port
PORT=8008

# Admin API Key
ADMIN_API_KEY=your-admin-key-here

# MongoDB Connection
MONGODB_URI=mongodb+srv://XXXX_db_user:XXXXXXXXX@poc0.rsin8mu.mongodb.net/?appName=poc0

# Frontend allowed pages (comma-separated): jti, hciot, home
VITE_PUBLIC_ALLOWED_PAGES=jti

# Restricted hosts (comma-separated)
VITE_PUBLIC_RESTRICTED_HOSTS=123.asd.ai
